# ===========================================
# CertPilot - Variables d'environnement
# ===========================================
# Copier ce fichier vers .env et remplir les valeurs

# Database - PostgreSQL (Railway ou autre)
DATABASE_URL="postgresql://user:password@host:port/database"

# Auth - NextAuth v5
# Génère une clé avec: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# URL publique de l'application (utilisée dans les emails, QR codes)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# Email - SMTP (Gmail ou autre)
# ===========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Alternative : Resend (si SMTP non configuré)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="CertPilot <contact@certpilot.eu>"

# ===========================================
# Stripe - Paiements
# ===========================================
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Price IDs Stripe (créés dans le dashboard Stripe)
STRIPE_PRICE_STARTER_MONTHLY="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_STARTER_ANNUAL="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_PRO_ANNUAL="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_MONTHLY="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_BUSINESS_ANNUAL="price_xxxxxxxxxxxxxxxxxxxx"

# ===========================================
# Cron & Admin
# ===========================================
# Protège l'endpoint /api/cron/check-alerts
# Génère une clé avec: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# Email de notification interne pour les nouvelles demandes
ADMIN_NOTIFICATION_EMAIL="contact@certpilot.eu"
